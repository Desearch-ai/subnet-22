# Copy to .env and fill in your values.
# Used by both the axon (miner.py) and the worker API (api.py).
# All values can also be passed as CLI args (CLI takes precedence).

# Bittensor wallet
WALLET_NAME=miner
WALLET_HOTKEY=default

# Chain
SUBTENSOR_NETWORK=finney
NETUID=22

# Axon (miner.py)
AXON_PORT=14000

# Worker API (api.py)
WORKER_HOST=0.0.0.0
WORKER_PORT=8000

# API keys
OPENAI_API_KEY=
SERPAPI_API_KEY=
APIFY_API_KEY=
